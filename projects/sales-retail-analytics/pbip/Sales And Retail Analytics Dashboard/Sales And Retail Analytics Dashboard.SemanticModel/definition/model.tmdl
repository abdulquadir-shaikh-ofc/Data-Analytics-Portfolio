model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["TMDLView_Desktop","DevMode"]

annotation PBI_QueryOrder = ["FactSales","DimProduct","DimGeography","DimDate","DimCustomer"]

ref table FactSales
ref table DimProduct
ref table DimGeography
ref table DimDate
ref table DimCustomer
ref table _Measures
ref table Parameter

ref cultureInfo en-US

