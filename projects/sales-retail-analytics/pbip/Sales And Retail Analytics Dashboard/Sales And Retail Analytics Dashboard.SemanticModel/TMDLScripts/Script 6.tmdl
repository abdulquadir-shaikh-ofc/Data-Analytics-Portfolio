		measure 'Repeat Customers' =
				
				CALCULATE(
				    DISTINCTCOUNT(FactSales[CustomerID]),
				    FILTER(
				        VALUES(FactSales[CustomerID]),
				        CALCULATE(DISTINCTCOUNT(FactSales[OrderID])) > 1
				    )
				)
			formatString: 0
			lineageTag: a53b46a9-fde2-49d5-b5b9-7b117c530fcc

		measure 'Avg Customer Orders' =
				
