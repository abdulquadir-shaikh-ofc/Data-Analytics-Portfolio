				    [Sales YoY Growth] >= 0.15, "#10B981",  // Strong Green
				    [Sales YoY Growth] >= 0.05, "#84CC16",  // Light Green
				    [Sales YoY Growth] >= 0, "#F59E0B",     // Amber
