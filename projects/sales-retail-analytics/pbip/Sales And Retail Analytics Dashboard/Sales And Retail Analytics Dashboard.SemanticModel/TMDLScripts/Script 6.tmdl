		measure 'New Customers' = ```
				
				CALCULATE(
				    DISTINCTCOUNT(FactSales[CustomerID]),
				    FILTER(
				        ALL(FactSales),
				        FactSales[OrderDate] = 
				            CALCULATE(
				                MIN(FactSales[OrderDate]),
				                ALLEXCEPT(FactSales, FactSales[CustomerID])
				            )
				    )
				)
				```
			formatString: 0
			lineageTag: 405bfddf-ca56-49dc-9c7b-db9f8082161a

		measure 'Repeat Customer Rate' =
				
				DIVIDE([Repeat Customers], [Total Customers], 0)
			lineageTag: 7c4c96af-8764-47d4-b791-d6334c79c65f

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		measure 'Product Performance Category' = ```
				
				VAR ProductSales = [Total Sales]
				VAR ProductProfit = [Total Profit]
				VAR AvgSales = CALCULATE([Total Sales], ALL(FactSales[ProductName])) / DISTINCTCOUNT(FactSales[ProductName])
				RETURN
				SWITCH(
				    TRUE(),
				    ProductProfit > 0 && ProductSales > AvgSales, "⭐ High Performer",
				    ProductProfit > 0 && ProductSales <= AvgSales, "✓ Profitable",
				    ProductProfit <= 0, "⚠ Loss Maker",
				    "→ Average"
				)
				
				```
			lineageTag: b3f0438d-a74f-47de-ad20-bb6f0bd4425b

		measure 'Products Above Avg Sales' =
				
				VAR AvgSales = DIVIDE([Total Sales], [Total Products], 0)
				RETURN
				CALCULATE(
				    [Total Products],
				    FILTER(
				        VALUES(FactSales[ProductName]),
				        [Total Sales] > AvgSales
				    )
				)
			formatString: 0
			lineageTag: 1453bce2-2329-4f51-8d34-c687694ac6bb

		measure 'Best Performing Region' =
				
				CALCULATE(
				    FIRSTNONBLANK(FactSales[Region], [Total Sales]),
				    TOPN(1, ALL(FactSales[Region]), [Total Sales])
				)
			lineageTag: a9f359cf-56ef-4aff-b991-23949c44dbe7

		measure 'Best Performing Category' = ```
				
