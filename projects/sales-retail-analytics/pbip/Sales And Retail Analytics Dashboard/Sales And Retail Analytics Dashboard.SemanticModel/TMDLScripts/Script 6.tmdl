		measure 'Sales Pareto 80%' = ```
				
				VAR TotalSalesValue = [Total Sales]
				VAR CumulativeSales = 
				    CALCULATE(
				        [Total Sales],
				        FILTER(
				            ALL(Sales[ProductName]),
				            [Total Sales] >= EARLIER([Total Sales])
				        )
				    )
				RETURN
				IF(CumulativeSales <= TotalSalesValue * 0.8, "Top 80%", "Bottom 20%")
				```
			lineageTag: 7e7c0a1d-849b-4e2b-bf2a-58df4fc98d79

		measure 'ABC Classification' = ```
				
				VAR ProductSales = [Total Sales]
				VAR AllSales = CALCULATE([Total Sales], ALL(FactSales[ProductName]))
				VAR Contribution = DIVIDE(ProductSales, AllSales, 0)
				RETURN
				SWITCH(
				    TRUE(),
				    Contribution >= 0.2, "A - High Value",
				    Contribution >= 0.05, "B - Medium Value",
				    "C - Low Value"
				)
				
				```
			lineageTag: 4ed6377a-3438-43e6-bd6d-bb68cf66b9d4

		measure 'Sales Volatility' =
				
				STDEV.P(FactSales[Sales])
			lineageTag: 3c27bfa4-da42-4c6d-9151-48efc2d53951

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		measure 'Coefficient of Variation' =
				
				DIVIDE([Sales Volatility], AVERAGE(FactSales[Sales]), 0)
			lineageTag: a7e47f75-0d5b-4e51-8ea3-1af1bdcadae1

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		measure 'Min Order Value' =
				
				MIN(FactSales[Sales])
			formatString: 0
			lineageTag: bf4986cd-3d91-482c-b577-9890857d01f9

		measure 'Max Order Value' =
				
				MAX(FactSales[Sales])
			formatString: 0
			lineageTag: 93c2158f-5d8a-4f19-b9ae-6ff66a3ebee5

		measure 'Median Order Value' =
				
				MEDIAN(FactSales[Sales])
			lineageTag: 29ac51ad-90ac-471f-8d2b-18ffa5a011d5

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		measure 'Sales Std Dev' =
				
				STDEV.P(FactSales[Sales])
			lineageTag: 2cfb2055-c726-43f8-b7ad-29c11b85c648

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		measure 'Orders Missing Profit' = ```
				
				CALCULATE(
				    [Total Orders],
				    ISBLANK(FactSales[Profit])
				)
				
				```
			formatString: 0
			lineageTag: ee1a2955-3fce-43a8-bd1f-eb94d8151987

		measure 'Orders with Zero Sales' =
				
				CALCULATE(
				    [Total Orders],
				    FactSales[Sales] = 0
				)
			formatString: 0
			lineageTag: 74dfef41-93e1-42b8-ad4f-3694f6ddc953

		measure 'Negative Profit Orders' =
				
				CALCULATE(
				    [Total Orders],
				    FactSales[Profit] < 0
				)
			formatString: 0
			lineageTag: a1a5464c-b2c9-4f68-9fc0-fe4e47353585

		measure 'Data Quality Score' =
				
				1 - DIVIDE([Orders Missing Profit] + [Orders with Zero Sales], [Total Orders], 0)
			lineageTag: 71d529db-6cdd-425a-9f45-3c4f5aaad0b2

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		measure 'Avg Product Sales' =
				
				AVERAGEX(
				    VALUES(FactSales[ProductName]),
				    [Total Sales]
				)
			lineageTag: 5f92f331-1d1e-4f85-972e-f79fc32edcec

			annotation PBI_FormatHint = {"isGeneralNumber":true}

