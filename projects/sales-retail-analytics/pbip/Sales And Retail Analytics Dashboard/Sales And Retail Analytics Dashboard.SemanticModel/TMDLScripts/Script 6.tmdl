			lineageTag: f82934dc-99b1-4ba3-add0-0c43d3293f56

		measure 'Worst Performing Product' =
				
				CALCULATE(
				    FIRSTNONBLANK(FactSales[ProductName], [Total Profit]),
				    TOPN(1, ALL(FactSales[ProductName]), [Total Profit], ASC)
				)
			lineageTag: e6e3833a-48db-4cbf-b730-9abb5967933c

		measure 'Sales Trend Indicator' =
				
				VAR CurrentSales = [Total Sales]
				VAR PreviousSales = [Sales LY]
				RETURN
				SWITCH(
				    TRUE(),
				    CurrentSales > PreviousSales * 1.15, "↑↑ Strong Growth",
				    CurrentSales > PreviousSales * 1.05, "↑ Growth",
				    CurrentSales >= PreviousSales * 0.95, "→ Stable",
				    CurrentSales >= PreviousSales * 0.85, "↓ Slight Decline",
				    "↓↓ Significant Decline"
				)
			lineageTag: febd329c-f3e5-4746-aaf5-85115412ebd2

		measure 'Profit Trend Indicator' =
				
				VAR CurrentProfit = [Total Profit]
				VAR PreviousProfit = [Profit LY]
				RETURN
				SWITCH(
				    TRUE(),
				    CurrentProfit > PreviousProfit * 1.15, "↑↑ Strong Growth",
				    CurrentProfit > PreviousProfit * 1.05, "↑ Growth",
				    CurrentProfit >= PreviousProfit * 0.95, "→ Stable",
				    CurrentProfit >= PreviousProfit * 0.85, "↓ Slight Decline",
				    "↓↓ Significant Decline"
				)
			lineageTag: 5b5905d5-1e74-4814-8680-ce39069047a5

		measure 'Profit Color' =
				
				IF([Total Profit] > 0, "Green", "Red")
			lineageTag: 9600611f-ff52-49fb-baec-b6a714340a3a

		measure 'Profit Margin Color' =
				
				SWITCH(
				    TRUE(),
				    [Profit Margin %] >= 0.15, "#10B981",  // Green - Excellent
				    [Profit Margin %] >= 0.10, "#84CC16",  // Light Green - Good
				    [Profit Margin %] >= 0.05, "#F59E0B",  // Amber - Fair
				    "#EF4444"                               // Red - Poor
				)
			lineageTag: 5a5a0971-50f0-421e-b790-1e2516ae8144

		measure 'YoY Growth Color' = ```
				
